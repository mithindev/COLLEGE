% PERMS WITHIOUT REPETITION

%%
clc; clear all; close all;

A = ['ABCD'];
F = [];

for i = A
    for j = A(A~=i)
        for k = A(A~=j & A~=i)
            for l = A(A~=i & A~=j & A~=k)
                F = [F; i j k l];
            end
        end
    end
end

disp(F)

