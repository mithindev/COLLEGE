// File name: projects/01/Xor.hdl

/**
 * Exclusive-or gate:
 * out = not (a == b)
 */

CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Nand(a=a,b=a,out=out1);
    Nand(a=b,b=b,out=out2);
    And(a=a,b=out2,out=out3);
    And(a=b,b=out1,out=out4);
    Or(a=out3,b=out4,out=out);
}